PORT=8100
MONGO_URI=mongodb://localhost:27017/studentDB

# 32+ character random string used for AES level-2 encryption of stored data
BACKEND_SECRET=replace-with-strong-random-string

# Must match VITE_FRONTEND_SECRET in frontend/.env (used for AES level-1)
FRONTEND_SECRET=replace-with-strong-random-string

# Long random string used to sign JWTs
JWT_SECRET=replace-with-very-long-random-string

FRONTEND_URL=your_frontend_url